package ui;
import javax.swing.*;
import java.awt.*;
import java.util.List;          
import model.Notification;    
import dao.NotificationDAO;     
import dao.AlertEngine;         
import dao.SessionManager;      

public class ZooManagementUI extends JFrame {

    public ZooManagementUI() {
        setTitle(" Zoo Management System");
        setSize(900, 600);
        setDefaultCloseOperation(JFrame.EXIT_ON_CLOSE);
        setLocationRelativeTo(null);
        setLayout(new BorderLayout());

        JMenuBar menuBar = new JMenuBar();
        menuBar.setBackground(new Color(34, 45, 65));

        JMenu mainMenu = new JMenu("Tables");
        mainMenu.setForeground(Color.WHITE);
        mainMenu.setFont(new Font("Segoe UI", Font.BOLD, 16));

        // Correct table names + primary keys
        String[][] entities = {
                {"Staff", "StaffID"},
                {"Species", "SpeciesID"},
                {"Animal", "AnimalID"},
                {"Enclosure", "EnclosureID"},
                {"DietDetails", "DietID"},
                {"MedicalCheckup", "CheckupID"},
                {"QuarantineRecord", "QuarantineID"},
                {"Donor", "DonorID"},
                {"Sponsorship", "SponsorshipID"},
                {"FeedingSchedule", "ScheduleID"},
                {"FoodInfo", "FoodName"}
        };

        for (String[] entity : entities) {
            JMenu entityMenu = new JMenu(entity[0]);
            entityMenu.setFont(new Font("Segoe UI", Font.PLAIN, 14));
            addEntityActions(entityMenu, entity[0], entity[1]);
            mainMenu.add(entityMenu);
        }

        menuBar.add(mainMenu);

        JMenu helpMenu = new JMenu("Help");
        helpMenu.setForeground(Color.WHITE);
        helpMenu.setFont(new Font("Segoe UI", Font.BOLD, 16));

        JMenuItem about = new JMenuItem("About Zoo Management");
        about.addActionListener(e -> JOptionPane.showMessageDialog(this,
                "Zoo Management System\nManages animals, staff, donors, and more efficiently.",
                "About", JOptionPane.INFORMATION_MESSAGE));
        helpMenu.add(about);

        menuBar.add(helpMenu);
        setJMenuBar(menuBar);
        
     // In the ZooManagementUI constructor, add after setJMenuBar(menuBar):
        dao.AlertEngine.start();

        // Add a notification button to menuBar:
        JButton btnNotif = new JButton("🔔 Alerts");
        btnNotif.addActionListener(e -> showNotifications());
        menuBar.add(Box.createHorizontalGlue());
        menuBar.add(btnNotif);

        // Add this method:
        
        
        

        //  Welcome screen
        JPanel welcomePanel = new JPanel(new BorderLayout());
        welcomePanel.setBackground(Color.WHITE);
        JLabel title = new JLabel(" Welcome to Zoo Management System ", SwingConstants.CENTER);
        title.setFont(new Font("Segoe UI", Font.BOLD, 28));
        title.setForeground(Color.black);
        JLabel tagline = new JLabel("Manage animals, enclosures, staff, donors, and more — all in one place.",
                SwingConstants.CENTER);
        tagline.setFont(new Font("Segoe UI", Font.ITALIC, 16));
        tagline.setForeground(Color.black);
        welcomePanel.add(title, BorderLayout.CENTER);
        welcomePanel.add(tagline, BorderLayout.SOUTH);
        add(welcomePanel, BorderLayout.CENTER);

        setVisible(true);
    }
    
    private void showNotifications() {
        List<model.Notification> notifs = dao.NotificationDAO.getUnread();
        if (notifs.isEmpty()) {
            JOptionPane.showMessageDialog(this, "No new alerts.", "Notifications", JOptionPane.INFORMATION_MESSAGE);
            return;
        }
        StringBuilder sb = new StringBuilder();
        for (model.Notification n : notifs) {
            sb.append("[").append(n.getType()).append("] ").append(n.getMessage()).append("\n");
        }
        JOptionPane.showMessageDialog(this, sb.toString(), "Alerts (" + notifs.size() + ")", JOptionPane.WARNING_MESSAGE);
        dao.NotificationDAO.markAllRead();
    }

    private void addEntityActions(JMenu entityMenu, String entityName, String primaryKey) {
        String role = SessionManager.getRole();

        JMenuItem insert = new JMenuItem("Insert Record");
        JMenuItem update = new JMenuItem("Update Record");
        JMenuItem delete = new JMenuItem("Delete Record");
        JMenuItem view   = new JMenuItem("View Records");

        insert.addActionListener(e -> new TableOperationForm(entityName, primaryKey, "Insert"));
        update.addActionListener(e -> new TableOperationForm(entityName, primaryKey, "Update"));
        delete.addActionListener(e -> new TableOperationForm(entityName, primaryKey, "Delete"));
        view.addActionListener(e   -> new TableOperationForm(entityName, primaryKey, "View"));

        // Everyone can view
        entityMenu.add(view);

        switch (entityName) {

            case "MedicalCheckup":
            case "QuarantineRecord":
                // Vet: full access | Staff: view only (already added) | Admin: full
                if (role.equals("ADMIN") || role.equals("VET")) {
                    entityMenu.add(insert);
                    entityMenu.add(update);
                    entityMenu.add(delete);
                }
                break;

            case "Staff":
            case "Enclosure":
                // Admin: full | Staff: view only | Vet: no access
                if (role.equals("ADMIN")) {
                    entityMenu.add(insert);
                    entityMenu.add(update);
                    entityMenu.add(delete);
                }
                break;

            case "Donor":
            case "Sponsorship":
                // Admin only
                if (role.equals("ADMIN")) {
                    entityMenu.add(insert);
                    entityMenu.add(update);
                    entityMenu.add(delete);
                }
                break;

            case "FeedingSchedule":
            case "FoodInfo":
                // Admin: full | Staff: insert + view | Vet: view only
                if (role.equals("ADMIN")) {
                    entityMenu.add(insert);
                    entityMenu.add(update);
                    entityMenu.add(delete);
                } else if (role.equals("STAFF")) {
                    entityMenu.add(insert);
                }
                break;

            default:
                // Animal, Species, DietDetails — Admin: full | Staff: insert+view | Vet: view only
                if (role.equals("ADMIN")) {
                    entityMenu.add(insert);
                    entityMenu.add(update);
                    entityMenu.add(delete);
                } else if (role.equals("STAFF")) {
                    entityMenu.add(insert);
                }
                break;
        }
    }
    public static void main(String[] args) {
    	SwingUtilities.invokeLater(LoginPage::new);
    }
}
